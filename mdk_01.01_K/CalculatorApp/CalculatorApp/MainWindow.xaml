<Window x:Class="CalculatorApp.MainWindow"
 Icon="/calculator_icon.ico"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Простой калькулятор"
 Height="525"
 Width="350"
 Background="DimGray"
 ResizeMode="NoResize"
KeyDown="ClearButton_KeyDown"        
 WindowStartupLocation="CenterScreen">
    <!-- кнопка Z - очистить всё -->


    <Grid Margin="10">
        <!-- Определяем строки Grid -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
 Text="Калькулятор"
 FontSize="24"
 FontWeight="Bold"
 HorizontalAlignment="Center"
 Margin="0,0,0,20"/>
        <!-- Первое число -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Первое число:" FontSize="14"
Margin="0,0,0,5"/>
            <TextBox x:Name="FirstNumberTextBox"
 FontSize="16"
 Background="LightGray"
 Padding="5"
 Height="35"/>
        </StackPanel>
        <!-- Второе число -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Второе число:" FontSize="14"
Margin="0,0,0,5"/>
            <TextBox x:Name="SecondNumberTextBox"
 FontSize="16"
 Padding="5"
 Background="LightGray"
 Height="35"/>
        </StackPanel>
        <!-- Операции -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Выберите операцию:" FontSize="14"
Margin="0,0,0,10"/>
            <UniformGrid Rows="1" Columns="6">
                <Button x:Name="AddButton"
 Content="+"
 FontSize="20"
 Margin="0,0,5,0"
 Height="50"
 Background="SlateGray"
 Click="AddButton_Click"/>
                <Button x:Name="SubtractButton"
 Content="-"
 FontSize="20"
 Margin="0,0,5,0"
 Height="50"
 Background="SlateGray"
 Click="SubtractButton_Click"/>
                <Button x:Name="MultiplyButton"
 Content="×"
 FontSize="20"
 Margin="0,0,5,0"
 Height="50"
 Background="SlateGray"
 Click="MultiplyButton_Click"/>
                <Button x:Name="DivideButton"
 Content="÷"
 FontSize="20"
 Height="50"
 Margin="0,0,5,0"
 Background="SlateGray"
 Click="DivideButton_Click"/>
                               <Button x:Name="PowerButton"
Content="^"
FontSize="20"
Height="50"
Margin="0,0,5,0"
Background="SlateGray"
Click="PowerButton_Click"/>
                <Button x:Name="SquareRootButton"
Content="sqrt"
FontSize="20"
Height="50"
Margin="0,0,5,0"
Background="SlateGray"
Click="SquareRootButton_Click"/>

            </UniformGrid>
        </StackPanel>
        <!-- Результат -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Результат:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="ResultTextBox"
 FontSize="18"
 Padding="5"
 Height="40"
 IsReadOnly="True"
 Background="LightGray"
 FontWeight="Bold"/>
        </StackPanel>
        <!-- Кнопка очистки -->
        <Button Grid.Row="5"
 Content="Очистить"
 FontSize="16"
 Height="40"
 VerticalAlignment="Top"
 Background="orange"
 Click="ClearButton_Click"/>

        <TextBlock
            Grid.Row="7"
            FontSize="16"
            Text="История операций:"
        />
        
        <ListBox
            Grid.Row="7"
            FontSize="16"
            Margin="0,25,100,0"
            Background="Bisque"
            x:Name="HistoryBox"
            />

        <Button
            x:Name="ClearHistory_Button"
            Grid.Row="7"
            Margin="240,25,0,0"
            FontSize="16"
            Content="Очистить"
            Click="ClearHistoryButton_Click"
            />


    </Grid>
</Window>