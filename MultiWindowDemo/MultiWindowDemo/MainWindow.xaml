<Window x:Class="MultiWindowDemo.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Главное окно" Height="300" Width="400">
    <StackPanel Margin="20" >
        <TextBlock Text="Введите своё имя:" FontSize="14"/>
        <TextBox x:Name="NameTextBox" FontSize="14"/>
        <Button Content="Оформить заказ"
                FontSize="14" 
                Padding="8"
                Margin="0,25,0,0"
                Click="OpenProfileButton_Click"/>
        <TextBlock x:Name="PriceLabel"
 FontSize="32" />
    </StackPanel>
</Window>